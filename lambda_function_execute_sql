import json
import os

import pymysql

DB_HOST = os.environ.get("DB_HOST")
DB_USER = os.environ.get("DB_USER")
DB_PASSWORD = os.environ.get("DB_PASSWORD")
DB_NAME = os.environ.get("DB_NAME")

rds_connection = None


def connect_rds():
    global rds_connection
    try:
        if rds_connection:
            rds_connection.ping(reconnect=True)
            return rds_connection
    except Exception:
        # Connection is dead, recreate
        rds_connection = None

    try:
        rds_connection = pymysql.connect(
            host=DB_HOST,
            user=DB_USER,
            password=DB_PASSWORD,
            database=DB_NAME,
            cursorclass=pymysql.cursors.DictCursor,
        )
        return rds_connection
    except Exception as e:
        print(f"Error connecting to RDS: {e}")
        raise ConnectionError("Failed to connect to RDS") from e


def lambda_handler(event, context):

    print(f"\nEvent: {json.dumps(event, indent=2)}\n")

    actionGroup = event.get("actionGroup", "sql_executor")
    function = event.get("function", "execute_sql_query")
    session_attributes = event.get("sessionAttributes", {})
    prompt_session_attributes = event.get("promptSessionAttributes", {})

    sql = None
    refined_user_question = None
    to_store = True  # default

    try:
        # Extract parameters
        params = event.get("parameters", [])
        for p in params:
            name = p.get("name")
            value = p.get("value")

            if name == "query":
                sql = value

            elif name == "refined_user_question":
                refined_user_question = value

            elif name == "to_store":
                to_store = str(value).strip().lower() == "true"

        print(f"Parsed to_store: {to_store}")

        if not sql:
            raise ValueError("No SQL query provided in event.")

        print(f"\nExecuting SQL:\n{sql}\n")

        # Connect to DB
        conn = connect_rds()

        with conn.cursor() as cursor:
            cursor.execute(sql)
            result = cursor.fetchall()

        print(f"\nQuery returned {len(result)} rows; result: {result}\n")

        # Prepare response for Bedrock
        response_body = {
            "TEXT": {
                "body": json.dumps(
                    {
                        "refined_user_question": refined_user_question,
                        "executed_sql": sql,
                        "results": result,
                        "to_store": to_store,
                        "row_count": len(result),
                    }
                )
            }
        }

        function_response = {
            "actionGroup": actionGroup,
            "function": function,
            "functionResponse": {"responseBody": response_body},
        }

        return {
            "messageVersion": "1.0",
            "response": function_response,
            "sessionAttributes": session_attributes,
            "promptSessionAttributes": prompt_session_attributes,
        }

    except Exception as e:
        print(f"\nError: {e}\n")

        response_body = {
            "TEXT": {
                "body": json.dumps(
                    {
                        "refined_user_question": refined_user_question,
                        "to_store": False,
                        "error": str(e),
                        "query_attempted": sql,
                    }
                )
            }
        }

        function_response = {
            "actionGroup": actionGroup,
            "function": function,
            "functionResponse": {
                "responseState": "REPROMPT",
                "responseBody": response_body,
            },
        }

        return {
            "messageVersion": "1.0",
            "response": function_response,
            "sessionAttributes": session_attributes,
            "promptSessionAttributes": prompt_session_attributes,
        }
